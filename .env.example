# Postgres connection string.
# Easiest path: create a free database at https://neon.tech or https://supabase.com
# and paste the connection string here. Local Docker also works (see SETUP.md).
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Anthropic API key for the "Brief me" feature.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-..."
